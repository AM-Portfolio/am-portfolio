            },
            "response": []
        },
        {
            "name": "Get Preview",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"etfIsin\": \"INF204KB14I2\",\n    \"userId\": \"ssd2658\",\n    \"portfolioId\": \"163d0143-4fcb-480c-ac20-622f14e0e293\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8060/api/v1/basket/preview",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8060",
                    "path": [
                        "api",
                        "v1",
                        "basket",
                        "preview"
                    ]
                },
                "description": "Preview basket composition for a specific ETF against user's current holdings. Shows what stocks need to be bought to replicate the ETF."
            },
