                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"userId\": null,\n    \"userHoldings\": [\n        {\n            \"isin\": \"INE848E01016\",\n            \"symbol\": \"NHPC\",\n            \"sector\": \"Power Generation\",\n            \"currentValue\": 50000,\n            \"portfolioId\": \"manual-portfolio-1\",\n            \"portfolioName\": \"Test Portfolio\"\n        },\n        {\n            \"isin\": \"INE040A01034\",\n            \"symbol\": \"HDFC\",\n            \"sector\": \"Banking\",\n            \"currentValue\": 75000,\n            \"portfolioId\": \"manual-portfolio-1\",\n            \"portfolioName\": \"Test Portfolio\"\n        }\n    ]\n}"
                },
                "url": {
