                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"timeFrame\": \"1M\",\n    \"fromDate\": \"2026-04-01\",\n    \"toDate\": \"2026-05-01\",\n    \"coreIdentifiers\": {\n        \"indexSymbol\": \"NIFTY50\"\n    },\n    \"pagination\": {\n        \"returnAllData\": true\n    }\n}"
