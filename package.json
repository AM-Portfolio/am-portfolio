{
  "name": "am-portfolio",
  "version": "1.0.0",
  "description": "Portfolio Monorepo Orchestrator",
  "scripts": {
    "build": "mvn clean install -DskipTests",
    "build:all": "npm run build",
    "build:common": "mvn clean install -f am-common-data/pom.xml -DskipTests",
    "build:module": "mvn clean install -am -amd -DskipTests -pl",
    "preprod:compile": "mvn -pl portfolio-app -am compile -DskipTests -B",
    "preprod:start": "npx -y dotenv-cli -e .env.preprod -- mvn -f portfolio-app/pom.xml spring-boot:run",
    "run:preprod": "npm run preprod:compile && npm run preprod:start",
    "dev:compile": "mvn -pl portfolio-app -am compile -DskipTests -B",
    "dev:start": "npx -y dotenv-cli -e .env.dev -- mvn -f portfolio-app/pom.xml spring-boot:run",
    "run:dev": "npm run dev:compile && npm run dev:start",
    "env:from-vault": "python scripts/map_env_from_vault_backup.py",
    "env:preprod": "python scripts/map_env_from_vault_backup.py --env preprod",
    "env:dev": "python scripts/map_env_from_vault_backup.py --env dev",
    "test": "mvn test",
    "sdk:generate:java": "npx @openapitools/openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g java -o sdk/java --skip-validate-spec",
    "sdk:generate:python": "npx @openapitools/openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g python -o sdk/python --skip-validate-spec",
    "sdk:generate:flutter": "npx @openapitools/openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g dart -o sdk/flutter --skip-validate-spec",
    "sdk:generate:all": "npm run sdk:generate:java && npm run sdk:generate:python && npm run sdk:generate:flutter",
    "docker:build": "docker build -t am-portfolio:latest .",
    "docker:run": "docker run -p 8080:8080 am-portfolio:latest"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.4"
  }
}
