# AM Portfolio — placeholders only (committed). Copy to gitignored env files:
#   copy .env.template .env.preprod   →  npm run run:preprod
#   copy .env.template .env.dev       →  npm run run:dev
# Or: npm run env:preprod | npm run env:dev
#     npm run env:from-vault -- --env preprod|dev [--backup <path>]

SPRING_PROFILES_ACTIVE=preprod

# Local port (8080 often taken by Windows AgentService on dev machines)
SERVER_PORT=8072

# --- Service URLs ---
# preprod
ETF_API_URL=https://am.asrax.in/parser
MARKET_DATA_API_URL=https://am.asrax.in/market
# ETF constituent ISIN mapping via POST .../v1/securities/batch-search (requires reachable market API)
BASKET_HOLDINGS_ENRICHMENT=true
MARKET_DATA_CONNECT_TIMEOUT_MS=5000
MARKET_DATA_READ_TIMEOUT_MS=45000
# Local market-data instead of preprod URL: MARKET_DATA_API_URL=http://localhost:8092
# dev (uncomment when SPRING_PROFILES_ACTIVE=dev)
# ETF_API_URL=https://am-dev.asrax.in/parser
# MARKET_DATA_API_URL=https://am-dev.asrax.in/market

# --- MongoDB (Vault: apps/{env}/infra/mongodb → url + /portfolio) ---
MONGODB_URL=mongodb://admin:YOUR_MONGO_PASSWORD@mongodb.asrax.in:8888/portfolio?authSource=admin&directConnection=true
MONGODB_DATABASE=portfolio

# --- Kafka (disabled for local run; Vault: apps/{env}/infra/kafka) ---
KAFKA_BOOTSTRAP_SERVERS=kafka.asrax.in:9092
KAFKA_USERNAME=kafkaUser
KAFKA_PASSWORD=YOUR_KAFKA_PASSWORD
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_ENABLED=false
PORTFOLIO_TOPIC=am-portfolio
PORTFOLIO_CONSUMER_ID=am-portfolio-group-1
STOCK_TOPIC=am-stock-price-update
STOCK_CONSUMER_ID=am-stock-group.v2
MARKET_INDEX_TOPIC=nse-stock-indices-update
MARKET_INDEX_CONSUMER_ID=am-market-index-group-1

# --- Redis (Vault: apps/{env}/infra/redis — VPS port 8889) ---
REDIS_HOSTNAME=redis.asrax.in
REDIS_PORT=8889
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# --- Auth (Vault: apps/{env}/services/am-auth) ---
JWT_SECRET=YOUR_JWT_SECRET
INTERNAL_SECRET_KEY=YOUR_INTERNAL_SECRET_KEY
JWT_ALGORITHM=HS256

LOG_LEVEL=INFO
